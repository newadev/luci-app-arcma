#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: MIT
# arcma init.d service — boot-time MAC randomization

START=21
USE_PROCD=1

EXTRA_COMMANDS="apply restore show"
EXTRA_HELP=\
"	apply		Apply random MAC addresses per config
	restore		Restore original MAC addresses
	show		Show current/original MAC info"

PROG=/usr/sbin/arcma

start_service() {
	local enabled
	enabled=$(uci -q get arcma.global.enabled 2>/dev/null)
	[ "${enabled}" = "1" ] || return 0

	local trigger
	trigger=$(uci -q get arcma.global.trigger 2>/dev/null)
	# trigger=ifup: handled by hotplug only, skip boot init
	[ "${trigger}" = "ifup" ] && return 0

	procd_open_instance
	procd_set_param command "${PROG}" uci-apply
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	return 0
}

apply() {
	"${PROG}" uci-apply
}

restore() {
	"${PROG}" uci-restore
}

show() {
	"${PROG}" show
}
